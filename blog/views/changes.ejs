<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; line-height: 1.6; background: #f4f4f4; }
    header { background: #333; color: #fff; padding: 1rem; }
    header h1 { display: inline-block; margin-right: 20px; }
    nav a { color: #fff; text-decoration: none; margin-right: 15px; }
    .container { max-width: 800px; margin: 20px auto; padding: 0 20px; }
    .change-form { background: #fff; padding: 25px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 20px; }
    .form-group { margin-bottom: 15px; }
    label { display: block; margin-bottom: 5px; font-weight: bold; }
    input, select, textarea { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; }
    button { background: #007bff; color: #fff; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; }
    button:hover { background: #0056b3; }
    .message { background: #d4edda; color: #155724; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
    .error { background: #f8d7da; color: #721c24; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
    .hidden { display: none; }
    .form-section { border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 5px; }
    .form-section h4 { margin-bottom: 10px; color: #333; }


  </style>
</head>
<body>
  <header>
    <h1>Blog</h1>
    <nav>
      <a href="/">Home</a>
      <a href="/new-author">New Author</a>
      <a href="/new-category">New Category</a>
      <a href="/new-entry">New Entry</a>
      <a href="/queries">Queries</a>
      <a href="/changes">Changes</a>
    </nav>
  </header>
  <div class="container">
    <h2>Data Changes</h2>
    
    <% if (message) { %>
      <div class="message"><%= message %></div>
    <% } %>
    
    <form class="change-form" action="/changes" method="POST">
      <div class="form-group">
        <label>Select Operation</label>
        <select name="changeType" id="changeType" onchange="showFields()">
          <option value="">-- Select an operation --</option>
          <option value="add-author">Add/Change Author to Entry</option>
          <option value="add-hashtag">Add Hashtag to Newest Entry</option>
          <option value="rename-category">Rename Category</option>
          <option value="upsert-entry">Upsert Entry</option>
          <option value="delete-entry">Delete Entry and Comments</option>
        </select>
      </div>
      
      <div id="add-author-fields" class="form-section hidden">
        <h4>Add/Change Author</h4>
        <div class="form-group">
          <label>Entry</label>
          <select name="entryId">
            <option value="">Select Entry</option>
            <% if (typeof entries !== 'undefined' && entries) { %>
              <% entries.forEach(entry => { %>
                <option value="<%= entry._id %>"><%= entry.title %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>New Author</label>
          <select name="newAuthor">
            <option value="">Select Author</option>
            <% if (typeof users !== 'undefined' && users) { %>
              <% users.forEach(user => { %>
                <option value="<%= user._id %>"><%= user.username %> (<%= user.name.firstname %> <%= user.name.lastname %>)</option>
              <% }); %>
            <% } %>
          </select>
        </div>
      </div>
      
      <div id="add-hashtag-fields" class="form-section hidden">
        <h4>Add Hashtag to Newest Entry</h4>
        <div class="form-group">
          <label>Hashtag</label>
          <input type="text" name="hashtag" placeholder="Enter hashtag (without #)">
        </div>
      </div>
      
      <div id="rename-category-fields" class="form-section hidden">
        <h4>Rename Category</h4>
        <div class="form-group">
          <label>Category</label>
          <select name="categoryId">
            <option value="">Select Category</option>
            <% if (typeof categories !== 'undefined' && categories) { %>
              <% categories.forEach(cat => { %>
                <option value="<%= cat._id %>"><%= cat.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>New Name</label>
          <input type="text" name="newName" placeholder="New category name">
        </div>
      </div>
      
      <div id="upsert-entry-fields" class="form-section hidden">
        <h4>Upsert Entry</h4>
        <div class="form-group">
          <label>Title</label>
          <input type="text" name="upsertTitle" placeholder="Entry title">
        </div>
        <div class="form-group">
          <label>Author</label>
          <select name="upsertAuthor">
            <option value="">Select Author</option>
            <% if (typeof users !== 'undefined' && users) { %>
              <% users.forEach(user => { %>
                <option value="<%= user._id %>"><%= user.username %> (<%= user.name.firstname %> <%= user.name.lastname %>)</option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="upsertDescription" placeholder="Entry description"></textarea>
        </div>
      </div>
      
      <div id="delete-entry-fields" class="form-section hidden">
        <h4>Delete Entry and Comments</h4>
        <div class="form-group">
          <label>Entry to Delete</label>
          <select name="deleteEntryId">
            <option value="">Select Entry</option>
            <% if (typeof entries !== 'undefined' && entries) { %>
              <% entries.forEach(entry => { %>
                <option value="<%= entry._id %>"><%= entry.title %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
      </div>
      
      <button type="submit">Execute</button>
    </form>
  </div>
  
  <script>
    function showFields() {
      const changeType = document.getElementById('changeType').value;
      const sections = ['add-author-fields', 'add-hashtag-fields', 'rename-category-fields', 'upsert-entry-fields', 'delete-entry-fields'];
      sections.forEach(s => document.getElementById(s).classList.add('hidden'));
      
      if (changeType === 'add-author') {
        document.getElementById('add-author-fields').classList.remove('hidden');
      } else if (changeType === 'add-hashtag') {
        document.getElementById('add-hashtag-fields').classList.remove('hidden');
      } else if (changeType === 'rename-category') {
        document.getElementById('rename-category-fields').classList.remove('hidden');
      } else if (changeType === 'upsert-entry') {
        document.getElementById('upsert-entry-fields').classList.remove('hidden');
      } else if (changeType === 'delete-entry') {
        document.getElementById('delete-entry-fields').classList.remove('hidden');
      }
    }
  </script>
</body>
</html>
